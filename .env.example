# Postgres (single instance, 3 logical DBs — see db/init)
POSTGRES_DB=auth_db
POSTGRES_USER=mizan_user
POSTGRES_PASSWORD=changeme

# Per-service datasource URLs (container-network hostnames for docker compose)
AUTH_DB_URL=jdbc:postgresql://postgres:5432/auth_db
USER_DB_URL=jdbc:postgresql://postgres:5432/user_db
CONTRACTS_DB_URL=jdbc:postgresql://postgres:5432/contracts_db

# Auth
JWT_SECRET=changeme-generate-a-256-bit-secret
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000

# Email verification (auth-service). Without real SMTP credentials, sending fails silently
# (registration still succeeds) — set LOG_VERIFICATION_LINKS=true for local dev so the
# verification link is printed to the auth-service logs instead of a real inbox. Never set
# LOG_VERIFICATION_LINKS=true outside local/dev — it logs a live, usable verification link.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false
MAIL_FROM_ADDRESS=noreply@mizan.ma
EMAIL_VERIFICATION_TOKEN_EXPIRATION_MS=86400000
VERIFICATION_RESEND_COOLDOWN_MS=60000
LOG_VERIFICATION_LINKS=false

# AI
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Shared secret for contracts-service -> ai-analysis-service direct calls
# (ai-analysis-service is not gateway-routed, see ADR-3 / architecture-mizan.md §5)
INTERNAL_SERVICE_TOKEN=changeme-generate-a-random-secret

# File storage (Cloudflare R2 in prod). For local dev, docker-compose.yml runs a LocalStack
# S3 stand-in — point these at it instead of real R2 (R2_ACCESS_KEY_ID=test, R2_SECRET_ACCESS_KEY=test,
# R2_ENDPOINT_URL=http://localstack:4566) so contracts-service works without real credentials.
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=mizan-contracts
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
CONTRACT_MAX_FILE_SIZE_MB=20

# Internal-only service URL (contracts-service -> ai-analysis-service, direct call not via Gateway)
AI_ANALYSIS_SERVICE_URL=http://ai-analysis-service:8084

# Frontend
FRONTEND_ORIGIN=http://localhost:4200
